{
  "name": "@volta-oss/automation-risk-checklist",
  "version": "3.0.0",
  "private": false,
  "type": "module",
  "description": "A preflight safety checklist for automations that touch customers, money, personal data, or public posts.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.js",
    "start": "python3 -m http.server 4173",
    "validate": "npm test",
    "certify": "npm run build && node --test test/v3.test.js",
    "test:all": "npm test",
    "test:rust": "cargo test --manifest-path backend/rust/Cargo.toml",
    "test:backend": "npm run test:rust",
    "clean": "rm -f src/*.js src/*.js.map src/*.d.ts test/*.js test/*.js.map test/*.d.ts",
    "ci": "npm ci && npm test && npm run test:backend --if-present",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "docker:build": "docker build -t volta-oss/automation-risk-checklist:local .",
    "docker:run": "docker compose up --build",
    "serve:rust": "cargo run --manifest-path backend/rust/Cargo.toml -- serve"
  },
  "keywords": [
    "ai-automation",
    "digital-equity",
    "local-first",
    "oss",
    "v3-production",
    "volta"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/volta-npo/automation-risk-checklist.git"
  },
  "homepage": "https://volta-npo.github.io/automation-risk-checklist/",
  "bugs": {
    "url": "https://github.com/volta-npo/automation-risk-checklist/issues"
  },
  "author": "Volta OSS Division <volta.npo@gmail.com>",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^25.9.1"
  }
}
